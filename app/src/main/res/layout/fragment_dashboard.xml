<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- Header Section -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/header_bg"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        app:cardBackgroundColor="?attr/colorPrimaryContainer"
        app:cardElevation="0dp"
        app:cardMaxElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="@dimen/content_max_width"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.None"
        app:strokeWidth="0dp">
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tv_inmate_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:text="Inmate Name"
        android:textColor="?attr/colorOnPrimaryContainer"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/header_bg"
        app:layout_constraintTop_toTopOf="@+id/header_bg" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_toggle_messaging"
        style="@style/Widget.Material3.Button.ElevatedButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:padding="0dp"
        android:contentDescription="Toggle Messaging"
        app:icon="@drawable/ic_toggle_messaging"
        app:iconSize="25dp"
        app:iconPadding="0dp"
        app:iconTint="@null"
        app:iconGravity="textStart"
        app:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_inmate_name"
        app:layout_constraintEnd_toStartOf="@+id/btn_logout"
        app:layout_constraintTop_toTopOf="@+id/tv_inmate_name" />

    <!-- Logout Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_logout"
        style="@style/Widget.Material3.Button.ElevatedButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:padding="0dp"
        android:contentDescription="Logout"
        app:icon="@drawable/ic_logout"
        app:iconTint="?attr/colorError"
        app:iconSize="22dp"
        app:iconPadding="0dp"
        app:iconGravity="textStart"
        app:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="@+id/btn_toggle_messaging"
        app:layout_constraintEnd_toEndOf="@+id/header_bg"
        app:layout_constraintTop_toTopOf="@+id/btn_toggle_messaging" />



    <!-- Balance Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_balance"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="-36dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header_bg"
        app:layout_constraintWidth_max="@dimen/content_max_width"
        app:strokeWidth="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <TextView
                android:id="@+id/tv_balance_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Available Balance (Monthly)"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp"
                android:textStyle="normal"
                android:letterSpacing="0.05"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_balance_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="00:00:00 hours"
                android:textColor="?attr/colorOnSurface"
                android:textSize="26sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_balance_label" />

            <!-- 🌟 Premium Linear Progress Indicator (Smooth Material 3 Style) -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/pb_balance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:progress="45"
                app:trackColor="?attr/colorSurfaceVariant"
                app:trackCornerRadius="4dp"
                app:trackThickness="8dp"
                app:indicatorColor="?attr/colorPrimary"
                app:layout_constraintTop_toBottomOf="@+id/tv_balance_value"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Contacts Label Section -->
    <TextView
        android:id="@+id/tv_contacts_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:text="Contacts"
        android:textColor="?attr/colorOnSurface"
        android:textSize="20sp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/card_balance" />

    <!-- 🌟 Clean & Smooth RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_contacts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_contacts_label"
        tools:listitem="@layout/item_contact" />

    <!-- Empty Contacts Message -->
    <TextView
        android:id="@+id/tv_empty_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No contacts added for you"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="16sp"
        android:textStyle="normal"
        android:letterSpacing="0.02"
        android:visibility="gone"
        android:gravity="center"
        android:drawableTop="@drawable/ic_no_contacts"
        android:drawablePadding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_contacts_label"
        app:layout_constraintVertical_bias="0.25" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_dialer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:contentDescription="Open Dialer"
        android:src="@drawable/ic_call"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>