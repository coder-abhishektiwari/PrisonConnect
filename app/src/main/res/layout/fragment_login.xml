<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:padding="32dp">

    <!-- Entry Title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter Prisoner ID"
        android:textColor="?attr/colorOnSurface"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/tv_welcome"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- Welcome header shown after prisoner ID verified -->
    <TextView
        android:id="@+id/tv_welcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="?attr/colorOnSurface"
        android:textSize="22sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/btn_change_prisoner"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_title" />

    <!-- Change Prisoner Option Link (Clean Constraints Applied) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_change_prisoner"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Change prisoner >"
        android:textColor="?attr/colorPrimary"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/ll_pin_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_welcome" />

    <!-- Square Fields for Digits (Now cleanly pushed down sequentially) -->
    <LinearLayout
        android:id="@+id/ll_pin_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/gl_buttons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_change_prisoner">

        <!-- Box 1 -->
        <TextView
            android:id="@+id/tv_pin_box1"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_pin_box"
            android:gravity="center"
            android:textColor="?attr/colorOnSurface"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Box 2 -->
        <TextView
            android:id="@+id/tv_pin_box2"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_pin_box"
            android:gravity="center"
            android:textColor="?attr/colorOnSurface"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Box 3 -->
        <TextView
            android:id="@+id/tv_pin_box3"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_pin_box"
            android:gravity="center"
            android:textColor="?attr/colorOnSurface"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Box 4 -->
        <TextView
            android:id="@+id/tv_pin_box4"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_pin_box"
            android:gravity="center"
            android:textColor="?attr/colorOnSurface"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Box 5 -->
        <TextView
            android:id="@+id/tv_pin_box5"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_pin_box"
            android:gravity="center"
            android:textColor="?attr/colorOnSurface"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Box 6 -->
        <TextView
            android:id="@+id/tv_pin_box6"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_pin_box"
            android:gravity="center"
            android:textColor="?attr/colorOnSurface"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Keypad Grid -->
    <GridLayout
        android:id="@+id/gl_buttons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:columnCount="3"
        android:rowCount="4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_pin_container">

        <!-- Row 1 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_1"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_margin="10dp"
            android:text="1"
            android:textSize="22sp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_2"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_margin="10dp"
            android:text="2"
            android:textSize="22sp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_3"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_margin="10dp"
            android:text="3"
            android:textSize="22sp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        <!-- Row 2 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_4"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_margin="10dp"
            android:text="4"
            android:textSize="22sp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_5"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_margin="10dp"
            android:text="5"
            android:textSize="22sp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_6"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_margin="10dp"
            android:text="6"
            android:textSize="22sp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        <!-- Row 3 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_7"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_margin="10dp"
            android:text="7"
            android:textSize="22sp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_8"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_margin="10dp"
            android:text="8"
            android:textSize="22sp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_9"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_margin="10dp"
            android:text="9"
            android:textSize="22sp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        <!-- Row 4 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_margin="10dp"
            app:icon="@drawable/ic_clear_all"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="28dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_0"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_margin="10dp"
            android:text="0"
            android:textSize="22sp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_margin="10dp"
            app:icon="@drawable/ic_backspace"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="28dp" />
    </GridLayout>

    <!-- Loader -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:indeterminate="true"
        android:indeterminateTint="?attr/colorPrimary"
        android:indeterminateTintMode="src_atop"
        android:theme="@style/Widget.Material3.CircularProgressIndicator"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>