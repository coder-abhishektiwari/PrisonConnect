<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk-auto"
    xmlns:app2="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- LOBBY CONTAINER -->
    <LinearLayout
        android:id="@+id/lobby_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="visible">

        <TextView
            android:id="@+id/tv_lobby_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Secure Video Terminal"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_lobby_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="Initializing secure link..."
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <ProgressBar
            android:id="@+id/lobby_progress"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:indeterminate="true"
            android:indeterminateTint="?attr/colorPrimary" />

        <!-- Link Copy Section -->
        <LinearLayout
            android:id="@+id/ll_lobby_link"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="?attr/colorSurfaceVariant"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_lobby_link"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Generating link..."
                android:textAppearance="?attr/textAppearanceBodySmall" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_copy_link"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app2:icon="@drawable/ic_copy_share"
                app2:iconSize="18dp"
                app2:iconTint="?attr/colorPrimary" />
        </LinearLayout>

        <!-- OTP Copy Section -->
        <LinearLayout
            android:id="@+id/ll_lobby_otp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="?attr/colorSurfaceVariant"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_lobby_otp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OTP: ---"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_copy_otp"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                app2:icon="@drawable/ic_copy_share"
                app2:iconSize="18dp"
                app2:iconTint="?attr/colorPrimary" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel_call"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="Cancel Call"
            android:textAllCaps="false" />
    </LinearLayout>

    <!-- VIDEO CALL UI -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/video_call_ui"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="invisible">

        <org.webrtc.SurfaceViewRenderer
            android:id="@+id/remote_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <View
            android:id="@+id/video_click_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <org.webrtc.SurfaceViewRenderer
            android:id="@+id/local_view"
            android:layout_width="120dp"
            android:layout_height="160dp"
            android:layout_margin="16dp"
            android:background="@android:color/black"
            app2:layout_constraintEnd_toEndOf="parent"
            app2:layout_constraintTop_toBottomOf="@+id/video_header"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Header -->
        <LinearLayout
            android:id="@+id/video_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_timer_overlay"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp"
            app2:layout_constraintEnd_toEndOf="parent"
            app2:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="300dp">

            <TextView
                android:id="@+id/tv_video_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="Robert Smith" />

            <TextView
                android:id="@+id/tv_video_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_video_balance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp"
                tools:text="Bal: 00:00:00" />
        </LinearLayout>

        <!-- Footer -->
        <LinearLayout
            android:id="@+id/video_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:background="@drawable/bg_timer_overlay"
            android:gravity="center"
            android:orientation="horizontal"
            app2:layout_constraintBottom_toBottomOf="parent"
            app2:layout_constraintEnd_toEndOf="parent"
            app2:layout_constraintStart_toStartOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_video_mic"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                app2:icon="@drawable/ic_mic"
                android:background="@drawable/bg_control_button"
                app2:backgroundTint="@null"
                app2:iconTint="@android:color/white"
                app2:iconGravity="textStart"
                app2:iconPadding="0dp"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btn_video_hangup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:src="@drawable/ic_call_end_down"
                app2:backgroundTint="?attr/colorError"
                app2:elevation="0dp"
                app2:fabSize="normal"
                app2:tint="@android:color/white"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_video_switch"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                app2:icon="@drawable/ic_camera_switch"
                android:background="@drawable/bg_control_button"
                app2:backgroundTint="@null"
                app2:iconTint="@android:color/white"
                app2:iconGravity="textStart"
                app2:iconPadding="0dp"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>