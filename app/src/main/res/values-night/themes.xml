<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.PrisonConnect" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main Brand Colors -->
        <item name="colorPrimary">@color/brand_primary_light</item>
        <item name="colorOnPrimary">@color/brand_primary_dark</item>
        <item name="colorPrimaryContainer">@color/brand_primary_dark</item>
        <item name="colorOnPrimaryContainer">@color/brand_primary_light</item>

        <!-- Secondary & Surface Colors -->
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_light</item>
        <item name="colorOnSurfaceVariant">@color/text_muted_light</item>
        <item name="colorSurfaceVariant">@color/surface_variant_dark</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">?attr/colorSurface</item>

        <!-- Error / Logout Button -->
        <item name="colorError">@color/premium_error</item>
    </style>
</resources>
