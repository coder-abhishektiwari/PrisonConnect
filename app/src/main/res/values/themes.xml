<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.PrisonConnect" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main Brand Colors -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">#EFF6FF</item>
        <item name="colorOnPrimaryContainer">@color/brand_primary</item>

        <!-- Secondary & Surface Colors -->
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/text_dark</item>
        <item name="colorOnSurfaceVariant">@color/text_muted</item>
        <item name="colorSurfaceVariant">#F3F4F6</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/brand_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">?attr/colorSurface</item>

        <!-- Error / Logout Button -->
        <item name="colorError">@color/premium_error</item>
    </style>

    <style name="Theme.PrisonConnect.Dialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <style name="Theme.SmsProvider.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.Material3.BodyMedium</item>

        <item name="shapeAppearanceMediumComponent">@style/DialogShape</item>
    </style>

    <style name="DialogShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
</resources>